{
  "name": "dev-quotes",
  "version": "1.0.0",
  "description": "Wallpapers with developer quotes.",
  "main": "start.js",
  "author": "Jan Aagaard <jan@aagaard.net>",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=12",
    "yarn": ">=1.22"
  },
  "scripts": {
    "check-formatting": "prettier --check \"**/*.{css,html,js,json,md,scss,ts,tsx,yml}\"",
    "check-types": "tsc",
    "start": "tsx src/generateWallpapers.ts",
    "update-dependencies": "yarn upgrade-interactive && rm yarn.lock && yarn install"
  },
  "dependencies": {
    "@types/node": "^24.12.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "yarn@4.13.0"
}
